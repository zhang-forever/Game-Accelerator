<?xml version="1.0" encoding="windows-1252"?>

<!--
  WiX installer definition for Game Accelerator.
  Built via `cargo wix`. Produces a clickable MSI that installs the app and
  creates Start Menu and Desktop shortcuts.

  The UpgradeCode below must stay constant across releases so that new versions
  upgrade an existing install instead of installing side by side.
-->

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product
        Id="*"
        Name="Game Accelerator"
        UpgradeCode="7E3F2A18-5C4B-4D9E-A1F6-2B8C9D0E1F34"
        Manufacturer="mi"
        Language="1033"
        Codepage="1252"
        Version="$(var.Version)">

        <Package Id="*"
            Keywords="Installer"
            Description="Game Accelerator - Lightweight Windows game booster"
            Manufacturer="mi"
            InstallerVersion="450"
            Languages="1033"
            Compressed="yes"
            InstallScope="perMachine"
            SummaryCodepage="1252" />

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of [ProductName] is already installed. Setup will now exit." />

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1" />
        <Property Id="DiskPrompt" Value="Game Accelerator Installation" />

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder" Name="PFiles">
                <Directory Id="APPLICATIONFOLDER" Name="Game Accelerator">
                    <Component Id="MainExecutable" Guid="9A1B2C3D-4E5F-6071-8293-A4B5C6D7E8F9">
                        <File Id="exe0"
                            Name="game-accelerator.exe"
                            DiskId="1"
                            Source="$(var.CargoTargetBinDir)\game-accelerator.exe"
                            KeyPath="yes">
                            <Shortcut Id="startmenuShortcut"
                                Directory="ProgramMenuDir"
                                Name="Game Accelerator"
                                WorkingDirectory="APPLICATIONFOLDER"
                                Icon="ProductIcon"
                                IconIndex="0"
                                Advertise="yes" />
                            <Shortcut Id="desktopShortcut"
                                Directory="DesktopFolder"
                                Name="Game Accelerator"
                                WorkingDirectory="APPLICATIONFOLDER"
                                Icon="ProductIcon"
                                IconIndex="0"
                                Advertise="yes" />
                        </File>
                    </Component>
                </Directory>
            </Directory>

            <Directory Id="ProgramMenuFolder" Name="Programs">
                <Directory Id="ProgramMenuDir" Name="Game Accelerator">
                    <Component Id="ProgramMenuDir" Guid="B2C3D4E5-F607-1829-3A4B-5C6D7E8F9012">
                        <RemoveFolder Id="cleanupShortcut" On="uninstall" />
                        <RegistryValue Root="HKCU"
                            Key="Software\mi\Game Accelerator"
                            Type="string"
                            Value=""
                            KeyPath="yes" />
                    </Component>
                </Directory>
            </Directory>

            <Directory Id="DesktopFolder" Name="Desktop" />
        </Directory>

        <Feature Id="MainProgram"
            Title="Game Accelerator"
            Description="The main application."
            Level="1"
            ConfigurableDirectory="APPLICATIONFOLDER"
            AllowAdvertise="no"
            Display="expand"
            Absent="disallow">
            <ComponentRef Id="MainExecutable" />
            <ComponentRef Id="ProgramMenuDir" />
        </Feature>

        <Icon Id="ProductIcon" SourceFile="$(var.CargoTargetBinDir)\game-accelerator.exe" />
        <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
        <Property Id="ARPHELPLINK" Value="https://github.com/zhang-forever/Game-Accelerator" />

        <!-- Install into Program Files by default; let the user change it. -->
        <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />

        <UIRef Id="WixUI_InstallDir" />
        <UIRef Id="WixUI_ErrorProgressText" />
    </Product>
</Wix>
